# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# App URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Payload CMS
PAYLOAD_SECRET="generate-a-secure-random-string-here"
PAYLOAD_BLOB_READ_WRITE_TOKEN="your-public-vercel-blob-read-write-token"
PAYLOAD_BOOTSTRAP_ADMIN_EMAIL="support@yourcareshare.com"
PAYLOAD_BOOTSTRAP_ADMIN_PASSWORD="change-me"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_ASSISTANT_MODEL="gpt-5-mini"

# Resend (transactional email)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="CareShare <no-reply@yourcareshare.com>"

# Tremendous (gift-card ordering)
TREMENDOUS_API_KEY="your-tremendous-api-key"
TREMENDOUS_MODE="sandbox"
# TREMENDOUS_FUNDING_SOURCE_ID="optional-override-otherwise-first-available-is-used"
GIFT_MONTHLY_CAP_USD="200"

# Method Financial (liability/debt account linking)
METHOD_API_KEY="your-method-api-key"
METHOD_ENV="dev"

# For production:
# NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# To generate a secure PAYLOAD_SECRET, run:
# openssl rand -base64 32
